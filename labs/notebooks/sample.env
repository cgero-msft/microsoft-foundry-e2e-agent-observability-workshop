# ──────────────────────────────────────────────────────────────
#  Zava Bank Client Advisory Agent — Environment Variables
# ──────────────────────────────────────────────────────────────
#  Copy this file to .env and fill in your values.
#  ➜  cp sample.env .env
#
#  Variables marked [REQUIRED] must be set before running any lab.
#  Variables marked [OPTIONAL] enhance specific labs or features.
# ──────────────────────────────────────────────────────────────


# ── Azure AI Foundry Project ─────────────────────────────────
# [REQUIRED — all labs]
# FORMAT : https://<your-resource>.services.ai.azure.com/api/projects/<project-name>
# FIND IT: Azure AI Foundry portal → your project → Overview → Project endpoint
AZURE_AI_PROJECT_ENDPOINT=

# [REQUIRED — all labs]
# The name of your deployed chat model inside the Foundry project.
# FORMAT : gpt-4.1  (or whatever deployment name you chose)
# FIND IT: Azure AI Foundry portal → your project → Deployments
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4.1


# ── Red-Teaming / Direct Model Access ────────────────────────
# [REQUIRED — red-teaming labs only]
# The inference endpoint for your model deployment.
# FORMAT : https://<your-resource>.services.ai.azure.com/openai/deployments/<deployment>/chat/completions?api-version=2024-12-01-preview
# FIND IT: Azure AI Foundry portal → Deployments → your model → Endpoint URL
MODEL_ENDPOINT=

# [REQUIRED — red-teaming labs only]
# API key for the model endpoint above.
# FORMAT : 32-character hex string
# FIND IT: Azure AI Foundry portal → Deployments → your model → Key
# ⚠️  SENSITIVE — never commit this value to source control
MODEL_API_KEY=


# ── Observability / Tracing ──────────────────────────────────
# [OPTIONAL — tracing labs]
# Application Insights connection string for distributed tracing.
# FORMAT : InstrumentationKey=<guid>;IngestionEndpoint=https://...
# FIND IT: Azure Portal → Application Insights → Overview → Connection String
TELEMETRY_CONNECTION_STRING=

# Record full prompt/completion content in traces (useful for debugging).
AZURE_TRACING_GEN_AI_CONTENT_RECORDING_ENABLED=true

# Reduce SDK noise — only surface errors in console output.
AZURE_LOG_LEVEL=error


# ── Azure Subscription (optional) ────────────────────────────
# [OPTIONAL — only if scripts need to resolve resources by subscription]
# FORMAT : xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# FIND IT: Azure Portal → Subscriptions → your subscription → Subscription ID
AZURE_SUBSCRIPTION_ID=

# [OPTIONAL — only if scripts need to resolve resources by resource group]
# FORMAT : my-resource-group-name
# FIND IT: Azure Portal → Resource groups
AZURE_RESOURCE_GROUP=
